# Copy this file to .env and adjust as needed.
# The app works out-of-the-box WITHOUT Kafka (USE_KAFKA=false).

# ---------------------------------------------------------------
# Kafka (only required when USE_KAFKA=true)
# ---------------------------------------------------------------
USE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MARKET=market-data
KAFKA_TOPIC_ALERTS=market-alerts
KAFKA_GROUP_ID=streaming-app-group

# ---------------------------------------------------------------
# Data generation
# ---------------------------------------------------------------
# Comma-separated list of symbols to stream
SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA,META,NVDA,JPM,BTC-USD,ETH-USD

# Seconds between rounds of ticks (lower = faster stream)
TICK_INTERVAL=0.3

# Price volatility per tick (fraction of price, e.g. 0.002 = 0.2%)
VOLATILITY=0.002

# ---------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------
# Max price-history ticks kept per symbol
MAX_HISTORY=200

# Dashboard auto-refresh in milliseconds
REFRESH_INTERVAL_MS=1000

# Alert thresholds (percentage change from initial price)
ALERT_THRESHOLD_HIGH=1.5
ALERT_THRESHOLD_LOW=-1.5
